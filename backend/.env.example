# Application
APP_NAME="My Sales System"
APP_ENV=development
DEBUG=true

# Database
# SQLite (default for local development)
DATABASE_URL=sqlite:///./my_erp.db
# PostgreSQL example
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/my_erp
# MySQL example
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/my_erp

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Initial admin user (seeded by `python -m app.scripts.seed`)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMe!2026
INITIAL_ADMIN_FULL_NAME=Administrator

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
