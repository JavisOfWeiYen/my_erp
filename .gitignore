# =================================================================
# my_sales_system .gitignore
# =================================================================
# Secrets, build artifacts, dependencies, caches, IDE noise.

# ---- Secrets (NEVER commit) -------------------------------------
.env
*.env
!.env.example
backend/.env
frontend/.env

# ---- Python -----------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.eggs/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
pip-log.txt
pip-delete-this-directory.txt

# ---- SQLite / local DB ------------------------------------------
*.db
*.sqlite
*.sqlite3
backend/app.db
backend/*.db-journal

# ---- Alembic side files (keep versions/, drop temp) -------------
backend/alembic/versions/__pycache__/

# ---- Node / Vite ------------------------------------------------
node_modules/
dist/
dist-ssr/
.vite/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Build outputs ----------------------------------------------
build/
out/

# ---- Logs -------------------------------------------------------
*.log
logs/

# ---- OS / IDE noise ---------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Claude Code local state ------------------------------------
.claude/settings.local.json

# ---- Docs build outputs (keep sources) --------------------------
docs/_build/
