# my_erp seed configuration
# Copy to seed/.env and adjust as needed.

# Backend API base URL (no trailing slash).
API_BASE_URL=http://localhost:8000/api/v1

# Seed database URL. Used directly by the seed script for raw SQL timestamp
# backdating, so it MUST match the DATABASE_URL the backend is running with.
# Path is resolved relative to the seed/ working directory.
SEED_DATABASE_URL=sqlite:///../backend/seed.db

# Bootstrap admin credentials. Must match the account that
# `python -m app.scripts.seed` created in the seed database.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMe!2026
